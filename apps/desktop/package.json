{
  "name": "@mufutu/desktop",
  "version": "1.0.0",
  "description": "MUFUTU Desktop Application - Electron",
  "main": "dist/main.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "build:win": "npm run dist:win",
    "build:linux": "npm run dist:linux",
    "type-check": "node -e \"console.log('@mufutu/desktop: skipped — add tsconfig to enable type-check')\"",
    "postinstall": "echo 'Skipping electron-builder install-app-deps'"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "node-thermal-printer": "^4.6.0",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "com.mufutu.desktop",
    "productName": "MUFUTU",
    "directories": {
      "output": "release"
    },
    "files": ["dist/**/*", "node_modules/**/*"],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
