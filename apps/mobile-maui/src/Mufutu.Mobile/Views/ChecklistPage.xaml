<?xml version="1.0" encoding="utf-8" ?>
<views:FieldCampoPage
    x:Class="Mufutu.Mobile.Views.ChecklistPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Mufutu.Mobile.Views.Controls"
    xmlns:core="clr-namespace:Mufutu.Mobile.Core;assembly=Mufutu.Mobile.Core"
    xmlns:vm="clr-namespace:Mufutu.Mobile.ViewModels"
    xmlns:views="clr-namespace:Mufutu.Mobile.Views"
    Title="Checklist"
    Shell.NavBarIsVisible="False">

    <controls:FieldShellView
        ActiveRoute="checklist"
        SiteLabel="{Binding SiteLabel}"
        UserLabel="{Binding UserLabel}">
        <controls:FieldShellView.Body>
            <VerticalStackLayout Padding="16" Spacing="12">
                <Label Text="Tipo de equipamento" FontSize="14" TextColor="#8B9CB3" />
                <CollectionView ItemsSource="{Binding Templates}" HeightRequest="44" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="core:ChecklistTemplate">
                            <Button
                                Text="{Binding Label}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type views:ChecklistPage}}, Path=BindingContext.SelectTemplateCommand}"
                                CommandParameter="{Binding .}"
                                Padding="12,8"
                                BackgroundColor="#1A2332"
                                TextColor="#E8EDF4"
                                BorderColor="#2A3548"
                                BorderWidth="1"
                                CornerRadius="8" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView ItemsSource="{Binding Rows}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChecklistRow">
                            <Grid Padding="0,8" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding Label}" TextColor="#E8EDF4" VerticalOptions="Center" />
                                <CheckBox Grid.Column="1" IsChecked="{Binding IsChecked}" CheckedChanged="OnRowChecked" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </controls:FieldShellView.Body>
    </controls:FieldShellView>
</views:FieldCampoPage>
