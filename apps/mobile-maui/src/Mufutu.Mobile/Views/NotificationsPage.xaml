<?xml version="1.0" encoding="utf-8" ?>
<views:FieldCampoPage
    x:Class="Mufutu.Mobile.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Mufutu.Mobile.Views.Controls"
    xmlns:vm="clr-namespace:Mufutu.Mobile.ViewModels"
    xmlns:views="clr-namespace:Mufutu.Mobile.Views"
    Title="Notificações"
    Shell.NavBarIsVisible="False">

    <controls:FieldShellView
        ActiveRoute="notifications"
        SiteLabel="{Binding SiteLabel}"
        UserLabel="{Binding UserLabel}"
        HeaderRightText="{Binding UnreadCount, StringFormat='{0} novas'}">
        <controls:FieldShellView.Body>
            <Grid RowDefinitions="Auto,*" Padding="12">
                <Button
                    Grid.Row="0"
                    Text="Marcar todas como lidas"
                    Command="{Binding MarkAllReadCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#5BA8E8"
                    HorizontalOptions="End" />

                <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
                    <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label
                                Text="Sem notificações"
                                TextColor="#8B9CB3"
                                HorizontalOptions="Center"
                                Margin="0,40,0,0" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:NotificationItem">
                                <Border
                                    Margin="0,0,0,8"
                                    Padding="12"
                                    BackgroundColor="#1A2332"
                                    Stroke="#2A3548"
                                    StrokeShape="RoundRectangle 10">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type views:NotificationsPage}}, Path=BindingContext.OpenCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="#E8EDF4" />
                                        <Label Text="{Binding Message}" TextColor="#8B9CB3" FontSize="12" />
                                        <Label
                                            Text="Nova"
                                            TextColor="#5BA8E8"
                                            FontSize="11"
                                            IsVisible="{Binding Read, Converter={StaticResource InvertedBoolConverter}}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>
        </controls:FieldShellView.Body>
    </controls:FieldShellView>
</views:FieldCampoPage>
