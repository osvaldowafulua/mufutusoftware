<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Mufutu.Mobile.ViewModels"
             x:Class="Mufutu.Mobile.Views.ConnectivityPage"
             x:DataType="vm:ConnectivityViewModel"
             BackgroundColor="{StaticResource PageBackground}"
             Title="MUFUTU Campo">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="16">
            <Label Text="MUFUTU"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource MufutuBrandOrange}" />
            <Label Text="Modo Campo — teste de rede"
                   TextColor="{StaticResource TextMuted}"
                   FontSize="14" />

            <Border BackgroundColor="{StaticResource CardBackground}"
                    Stroke="{StaticResource MufutuPrimary}"
                    StrokeThickness="1"
                    Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Rede do dispositivo"
                           TextColor="{StaticResource TextPrimary}"
                           FontAttributes="Bold" />
                    <Label Text="{Binding NetworkLine}"
                           TextColor="{StaticResource TextMuted}" />
                    <Label Text="{Binding StatusLine}"
                           TextColor="{StaticResource TextPrimary}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Testar API novamente"
                    Command="{Binding RunProbeCommand}"
                    BackgroundColor="{StaticResource MufutuBrandOrange}"
                    TextColor="White"
                    HeightRequest="48" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="{StaticResource MufutuBrandOrange}"
                               HeightRequest="32" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
