<?xml version="1.0" encoding="utf-8" ?>
<views:FieldCampoPage
    x:Class="Mufutu.Mobile.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Mufutu.Mobile.Views"
    Title="{Binding LoginTitle}"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,32" Spacing="16">
            <Border
                WidthRequest="56"
                HeightRequest="56"
                StrokeThickness="0"
                BackgroundColor="#E8612D"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 12">
                <Label
                    Text="M"
                    FontSize="24"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>

            <Label
                Text="{Binding LoginHeading}"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="#E8EDF4"
                HorizontalTextAlignment="Center" />
            <Label
                Text="{Binding LoginSubtitle}"
                FontSize="13"
                TextColor="#8B9CB3"
                HorizontalTextAlignment="Center" />

            <Label Text="{Binding LanguageLabel}" FontSize="12" TextColor="#8B9CB3" Margin="0,8,0,0" />
            <Picker
                ItemsSource="{Binding LocaleOptions}"
                ItemDisplayBinding="{Binding Label}"
                SelectedItem="{Binding SelectedLocaleItem}"
                TextColor="#E8EDF4"
                BackgroundColor="#1A2332" />

            <Label Text="{Binding ApiLabel}" FontSize="12" TextColor="#8B9CB3" Margin="0,12,0,0" />
            <Entry
                Text="{Binding ApiUrl}"
                Placeholder="https://api.mufutu.ao/api"
                TextColor="#E8EDF4"
                PlaceholderColor="#5A6B80"
                BackgroundColor="#1A2332" />

            <Label Text="{Binding SiteLabel}" FontSize="12" TextColor="#8B9CB3" />
            <Entry
                Text="{Binding SiteCode}"
                Placeholder="MUA"
                TextColor="#E8EDF4"
                BackgroundColor="#1A2332" />

            <Label Text="{Binding EmailLabel}" FontSize="12" TextColor="#8B9CB3" />
            <Entry
                Text="{Binding Email}"
                Keyboard="Email"
                TextColor="#E8EDF4"
                BackgroundColor="#1A2332" />

            <Label Text="{Binding PasswordLabel}" FontSize="12" TextColor="#8B9CB3" />
            <Entry
                Text="{Binding Password}"
                IsPassword="True"
                TextColor="#E8EDF4"
                BackgroundColor="#1A2332" />

            <Label
                Text="{Binding ErrorMessage}"
                TextColor="#FF6B6B"
                FontSize="12"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Button
                Text="{Binding SignInLabel}"
                Command="{Binding LoginCommand}"
                BackgroundColor="#1565C0"
                TextColor="White"
                HeightRequest="48"
                CornerRadius="10"
                Margin="0,8,0,0" />

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#5BA8E8"
                HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</views:FieldCampoPage>
