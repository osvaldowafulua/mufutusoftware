<?xml version="1.0" encoding="utf-8" ?>
<views:FieldCampoPage
    x:Class="Mufutu.Mobile.Views.OtsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Mufutu.Mobile.Views.Controls"
    xmlns:vm="clr-namespace:Mufutu.Mobile.ViewModels"
    xmlns:views="clr-namespace:Mufutu.Mobile.Views"
    Title="Trabalhos"
    Shell.NavBarIsVisible="False">

    <controls:FieldShellView
        ActiveRoute="ots"
        SiteLabel="{Binding SiteLabel}"
        UserLabel="{Binding UserLabel}">
        <controls:FieldShellView.Body>
            <Grid RowDefinitions="Auto,*" Padding="12">
                <Label
                    Grid.Row="0"
                    Text="{Binding ErrorMessage}"
                    TextColor="#FF6B6B"
                    FontSize="12"
                    IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

                <RefreshView Grid.Row="1" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy}">
                    <CollectionView ItemsSource="{Binding Items}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label
                                Text="Sem trabalhos"
                                TextColor="#8B9CB3"
                                HorizontalOptions="Center"
                                Margin="0,40,0,0" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkOrderItem">
                                <Border
                                    Margin="0,0,0,10"
                                    Padding="14"
                                    BackgroundColor="#1A2332"
                                    Stroke="#2A3548"
                                    StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Number}" FontAttributes="Bold" TextColor="#5BA8E8" FontSize="13" />
                                        <Label Text="{Binding Title}" TextColor="#E8EDF4" FontSize="15" />
                                        <Label Text="{Binding AssetName}" TextColor="#8B9CB3" FontSize="12" />
                                        <Label Text="{Binding StatusLabel}" TextColor="#8B9CB3" FontSize="12" />
                                        <Button
                                            Text="{Binding ActionLabel}"
                                            IsVisible="{Binding CanAct}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type views:OtsPage}}, Path=BindingContext.ActCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#1565C0"
                                            TextColor="White"
                                            HeightRequest="44"
                                            CornerRadius="8"
                                            Margin="0,6,0,0" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>
        </controls:FieldShellView.Body>
    </controls:FieldShellView>
</views:FieldCampoPage>
