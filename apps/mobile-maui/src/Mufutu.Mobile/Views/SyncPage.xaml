<?xml version="1.0" encoding="utf-8" ?>
<views:FieldCampoPage
    x:Class="Mufutu.Mobile.Views.SyncPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:Mufutu.Mobile.Views.Controls"
    xmlns:views="clr-namespace:Mufutu.Mobile.Views"
    Title="Enviar"
    Shell.NavBarIsVisible="False">

    <controls:FieldShellView
        ActiveRoute="sync"
        SiteLabel="{Binding SiteLabel}"
        UserLabel="{Binding UserLabel}">
        <controls:FieldShellView.Body>
            <VerticalStackLayout Padding="16,24" Spacing="16">
                <Label Text="Ligação à API" FontSize="20" FontAttributes="Bold" TextColor="#E8EDF4" />
                <Label Text="{Binding StatusText}" FontSize="16" TextColor="#5BA8E8" />
                <Label Text="{Binding DetailText}" FontSize="13" TextColor="#8B9CB3" />
                <Label
                    Text="{Binding PendingCount, StringFormat='Pendentes: {0}'}"
                    FontSize="14"
                    TextColor="#E8612D" />

                <Button
                    Text="Enviar agora"
                    Command="{Binding SyncNowCommand}"
                    BackgroundColor="#E8612D"
                    TextColor="White"
                    HeightRequest="48"
                    CornerRadius="10" />
                <Button
                    Text="Testar ligação"
                    Command="{Binding ProbeCommand}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    HeightRequest="48"
                    CornerRadius="10"
                    Margin="0,8,0,0" />
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="#5BA8E8" />

                <BoxView HeightRequest="1" Color="#2A3548" Margin="0,16" />

                <Button
                    Text="Sair"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#FF6B6B"
                    BorderColor="#FF6B6B"
                    BorderWidth="1"
                    HeightRequest="48"
                    CornerRadius="10" />
            </VerticalStackLayout>
        </controls:FieldShellView.Body>
    </controls:FieldShellView>
</views:FieldCampoPage>
