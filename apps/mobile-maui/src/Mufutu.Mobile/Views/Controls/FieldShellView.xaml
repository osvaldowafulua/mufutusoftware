<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="Mufutu.Mobile.Views.Controls.FieldShellView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

    <Grid RowDefinitions="Auto,*,Auto" BackgroundColor="#0F1419">
        <!-- Header -->
        <Grid
            Grid.Row="0"
            Padding="14,10"
            ColumnDefinitions="Auto,*,Auto"
            BackgroundColor="#1A2332">
            <Border
                Grid.Column="0"
                WidthRequest="36"
                HeightRequest="36"
                StrokeThickness="0"
                BackgroundColor="#EB5E28"
                StrokeShape="RoundRectangle 8">
                <Label
                    Text="M"
                    FontSize="16"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Border>
            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" Spacing="0">
                <Label
                    Text="{Binding Source={x:Reference Root}, Path=SiteLabel}"
                    FontSize="13"
                    FontAttributes="Bold"
                    TextColor="#E8EDF4" />
                <Label
                    Text="{Binding Source={x:Reference Root}, Path=UserLabel}"
                    FontSize="11"
                    TextColor="#8B9CB3" />
            </VerticalStackLayout>
            <Label
                Grid.Column="2"
                Text="{Binding Source={x:Reference Root}, Path=HeaderRightText}"
                FontSize="11"
                TextColor="#5BA8E8"
                VerticalOptions="Center" />
        </Grid>

        <!-- Body -->
        <ContentPresenter
            Grid.Row="1"
            Content="{Binding Source={x:Reference Root}, Path=Body}" />

        <!-- Bottom nav -->
        <Grid
            Grid.Row="2"
            Padding="4,6,4,2"
            ColumnDefinitions="*,*,*,*,*"
            BackgroundColor="#1A2332"
            ColumnSpacing="2">
            <Button
                x:Name="NavHomeBtn"
                Grid.Column="0"
                Text="Início"
                FontSize="10"
                BackgroundColor="Transparent"
                TextColor="{Binding Source={x:Reference Root}, Path=NavHomeColor}"
                Clicked="OnNavHome" />
            <Button
                x:Name="NavOtsBtn"
                Grid.Column="1"
                Text="Trabalhos"
                FontSize="10"
                BackgroundColor="Transparent"
                TextColor="{Binding Source={x:Reference Root}, Path=NavOtsColor}"
                Clicked="OnNavOts" />
            <Button
                x:Name="NavAvariaBtn"
                Grid.Column="2"
                Text="Avaria"
                FontSize="10"
                BackgroundColor="Transparent"
                TextColor="{Binding Source={x:Reference Root}, Path=NavAvariaColor}"
                Clicked="OnNavAvaria" />
            <Button
                x:Name="NavChecklistBtn"
                Grid.Column="3"
                Text="Checklist"
                FontSize="10"
                BackgroundColor="Transparent"
                TextColor="{Binding Source={x:Reference Root}, Path=NavChecklistColor}"
                Clicked="OnNavChecklist" />
            <Button
                x:Name="NavSyncBtn"
                Grid.Column="4"
                Text="Enviar"
                FontSize="10"
                BackgroundColor="Transparent"
                TextColor="{Binding Source={x:Reference Root}, Path=NavSyncColor}"
                Clicked="OnNavSync" />
        </Grid>
    </Grid>
</ContentView>
