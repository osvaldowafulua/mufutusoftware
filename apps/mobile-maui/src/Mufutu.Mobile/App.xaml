<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:Mufutu.Mobile.Converters"
             x:Class="Mufutu.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <conv:NotNullConverter x:Key="NotNullConverter" />
            <Color x:Key="MufutuBrandOrange">#EB5E28</Color>
            <Color x:Key="MufutuPrimary">#1565C0</Color>
            <Color x:Key="PageBackground">#0F1419</Color>
            <Color x:Key="CardBackground">#1A222D</Color>
            <Color x:Key="TextPrimary">#E8EDF4</Color>
            <Color x:Key="TextMuted">#8B9CB3</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
