<?xml version='1.0'?>
<Obfuscator>
  <Var name="InPath" value="." />
  <Var name="OutPath" value=".\obfuscated" />
  <Var name="KeepPublicApi" value="true" />
  <Var name="HidePrivateApi" value="true" />
  <Var name="RenameProperties" value="true" />
  <Var name="RenameEvents" value="true" />
  <Var name="RenameFields" value="true" />
  <Var name="UseUnicodeNames" value="true" />
  <Var name="HideStrings" value="true" />
  <Module file="$(InPath)\Mufutu.Desktop.Core.dll">
    <SkipType name="Mufutu.Desktop.Core.Api.Models.*" />
    <SkipType name="Mufutu.Desktop.Core.Configuration.*" />
  </Module>
  <Module file="$(InPath)\Mufutu.Desktop.Licensing.dll" />
</Obfuscator>
